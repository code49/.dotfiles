# --- Global Defaults for your CMU hosts ---
# Applies to cmu, cmu-linux, and any machine matching the patterns below
Host cmu ece-linux ece-ssh ece0* hh-1305*
    User dchan2
    ForwardX11 yes
    ForwardX11Trusted yes
    ServerAliveInterval 60

# --- Standard Entry Points ---
Host cmu
    HostName unix.andrew.cmu.edu

Host ece-linux
    HostName linux.ece.cmu.edu

Host ece-ssh
    HostName ece001.ece.local.cmu.edu
    ProxyJump ece-linux

# --- ECE Clusters (Jump via cmu-linux) ---
# Usage: ssh ece030
# Auto-expands to: ece030.ece.local.cmu.edu
Host ece0*
    HostName %h.ece.local.cmu.edu
    ProxyJump ece-linux

# --- Hamerschlag Hall / Lab Machines (Jump via cmu-linux) ---
# Usage: ssh hh-1305-10
# Auto-expands to: hh-1305-10.lan.local.cmu.edu
Host hh-1305*
    HostName %h.lan.local.cmu.edu
    ProxyJump ece-linux
